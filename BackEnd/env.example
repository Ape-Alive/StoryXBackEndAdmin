# ==================== 服务器配置 ====================
NODE_ENV=development
PORT=5800

# ==================== 数据库配置 (Prisma) ====================
# MySQL 连接字符串格式: mysql://用户名:密码@主机:端口/数据库名
# 示例: mysql://root:password@localhost:3306/storyx_admin
DATABASE_URL="mysql://root:password@localhost:3306/storyx_admin?schema=public"

# ==================== JWT 配置 ====================
# JWT 密钥（生产环境请使用强随机字符串，建议至少32个字符）
# 可以使用以下命令生成随机密钥: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-change-in-production-please-use-strong-random-string
JWT_EXPIRES_IN=24h

# ==================== Redis 配置（可选） ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ==================== CORS 配置 ====================
# 前端应用地址，多个地址用逗号分隔
CORS_ORIGIN=http://localhost:3001

# ==================== 日志配置 ====================
LOG_LEVEL=info
LOG_DIR=./logs

# ==================== SMTP 配置（邮箱验证码） ====================
# SMTP 服务器配置（用于发送邮箱验证码）
# 如果使用 Gmail，需要使用应用专用密码
# 如果使用 QQ 邮箱，SMTP_HOST=smtp.qq.com, SMTP_PORT=587
# 如果使用 163 邮箱，SMTP_HOST=smtp.163.com, SMTP_PORT=465, SMTP_SECURE=true
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
SMTP_FROM=noreply@example.com

# ==================== 安全配置 ====================
# 是否启用请求限流
ENABLE_RATE_LIMIT=true
# 每分钟最大请求数
RATE_LIMIT_MAX=100

# ==================== OTA 更新配置 ====================
# 管控后台 API 对外基址（支付回调、产物 downloadUrl 等，开发环境用 5800）
API_BASE_URL=http://localhost:5800
API_PUBLIC_BASE_URL=http://127.0.0.1:5800

# OTA 产物 CDN/静态基址（upload 后生成的 downloadUrl 前缀）
OTA_PUBLIC_BASE_URL=http://127.0.0.1:5800

# Check API 限流：每 IP+deviceId 每分钟最大次数
OTA_CHECK_RATE_LIMIT=60

# Ed25519 签名（生成：npm run generate:ota-keys）
# 开发环境可设 false；生产环境务必 true 并配置密钥
OTA_REQUIRE_SIGNATURE=false
OTA_SIGNING_PRIVATE_KEY=
OTA_SIGNING_PUBLIC_KEY=

# 受保护渠道（默认 internal）访问 check/report 需请求头 X-OTA-Api-Key
OTA_PROTECTED_CHANNELS=internal
OTA_CHECK_API_KEY=

# 生产环境 downloadUrl 域名白名单（逗号分隔，留空则不限制）
# OTA_ALLOWED_DOWNLOAD_HOSTS=cdn.example.com,updates.example.com
# OTA_ENFORCE_DOWNLOAD_HOSTS=true

# /uploads/ota 产物访问：默认需 query 签名（expires+sig）。设 true 则公开静态访问（仅开发调试）
OTA_ARTIFACT_PUBLIC=false
# 签名密钥；留空则回退 JWT_SECRET
# OTA_ARTIFACT_SIGNING_SECRET=
# 签名 URL 有效期（秒），大包下载可适当加长
OTA_ARTIFACT_URL_TTL_SECONDS=7200

# 订单过期时间（分钟）
ORDER_EXPIRE_MINUTES=30

# ==================== 支付配置 ====================
# YunGouOS 支付配置
YUNGOUOS_MCH_ID=your_mch_id
YUNGOUOS_API_KEY=your_api_key
YUNGOUOS_API_BASE_URL=https://api.pay.yungouos.com
YUNGOUOS_NOTIFY_URL=http://localhost:5800/api/payment/callback/yungouos
YUNGOUOS_RETURN_URL=http://localhost:3001/payment/return

# 微信官方支付配置（预留）
# WECHAT_NOTIFY_URL=http://localhost:5800/api/payment/callback/wechat_official

# 支付宝官方支付配置（预留）
# ALIPAY_NOTIFY_URL=http://localhost:5800/api/payment/callback/alipay_official

# Stripe 支付配置（预留）
# STRIPE_SECRET_KEY=your_secret_key
# STRIPE_PUBLISHABLE_KEY=your_publishable_key
# STRIPE_WEBHOOK_SECRET=your_webhook_secret

# ==================== 激活码 ====================
# 未使用激活码默认有效天数
ACTIVATION_CODE_DEFAULT_EXPIRE_DAYS=30
# 过期激活码清理任务；设为 false 可禁用
ENABLE_ACTIVATION_CODE_EXPIRATION_JOB=true
# ACTIVATION_CODE_EXPIRE_CHECK_INTERVAL=600000

# ==================== 文件上传配置 ====================
# 上传文件大小限制（MB）
MAX_FILE_SIZE=10
