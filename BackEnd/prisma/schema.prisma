generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Admin {
  id                 String              @id @default(cuid())
  username           String              @unique
  email              String              @unique
  password           String
  role               String
  status             String              @default("active")
  lastLogin          DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  emailVerifications EmailVerification[]
  operationLogs      OperationLog[]

  @@index([username])
  @@index([email])
  @@map("admins")
}

model EmailVerification {
  id        String   @id @default(cuid())
  email     String
  code      String
  type      String
  adminId   String?
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  admin     Admin?   @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([code])
  @@index([type])
  @@index([used])
  @@index([expiresAt])
  @@index([adminId], map: "email_verifications_adminId_fkey")
  @@map("email_verifications")
}

model User {
  id                   String                 @id @default(cuid())
  email                String?                @unique
  phone                String?                @unique
  password             String?
  status               String                 @default("normal")
  banReason            String?
  banUntil             DateTime?
  lastLoginAt          DateTime?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  role                 String                 @default("basic_user")
  aiCallLogs           AICallLog[]
  authorizations       Authorization[]
  devices              Device[]
  oneTimeTokens        OneTimeToken[]
  orders               Order[]
  quotaRecords         QuotaRecord[]
  refreshTokens        RefreshToken[]
  apiKeys              UserApiKey[]
  packages             UserPackage[]
  quotas               UserQuota[]
  voiceProfiles        VoiceProfile[]
  voiceCloneCreditLogs VoiceCloneCreditLog[]
  activationCodesUsed  ActivationCode[]      @relation("ActivationCodeUsedBy")

  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([status])
  @@index([createdAt])
  @@map("users")
}

model RefreshToken {
  id          String    @id @default(cuid())
  userId      String
  deviceId    String?
  token       String    @unique @db.VarChar(767)
  accessToken String?   @db.VarChar(767)
  expiresAt   DateTime
  revoked     Boolean   @default(false)
  revokedAt   DateTime?
  lastUsedAt  DateTime?
  ipAddress   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([deviceId])
  @@index([expiresAt])
  @@index([revoked])
  @@map("refresh_tokens")
}

model OneTimeToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique @db.VarChar(767)
  used      Boolean   @default(false)
  usedAt    DateTime?
  expiresAt DateTime
  ipAddress String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([used])
  @@index([expiresAt])
  @@map("one_time_tokens")
}

model Device {
  id                String   @id @default(cuid())
  userId            String
  deviceFingerprint String
  ipAddress         String?
  region            String?
  lastUsedAt        DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  name              String?
  remark            String?
  status            String   @default("active")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceFingerprint])
  @@index([userId])
  @@index([deviceFingerprint])
  @@index([status])
  @@map("devices")
}

model AIProvider {
  id                        String       @id @default(cuid())
  name                      String       @unique
  displayName               String
  baseUrl                   String?
  website                   String?
  logoUrl                   String?
  description               String?
  isActive                  Boolean      @default(true)
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt
  mainAccountToken          String?
  quota                     Decimal?     @db.Decimal(20, 2)
  quotaUnit                 String?      @default("points")
  apiKeyCreationConfig      String?      @db.Text
  apiKeys                   String?      @db.Text
  supportsApiKeyCreation    Boolean      @default(false)
  apiKeyLowBalanceThreshold Decimal      @default(1000.00) @db.Decimal(20, 2)
  voiceCloneApis            String?      @db.Text
  /// 单次音色复刻（/api/voice-profiles/clone）从所选 UserApiKey 扣除的积分；0 表示不扣费
  voiceCloneCreditsPerCall  Decimal      @default(0.00) @db.Decimal(20, 2)
  models                    AIModel[]
  userApiKeys               UserApiKey[]
  voiceCloneCreditLogs      VoiceCloneCreditLog[]
  /// true=对全部客户端角色可见；false=见 catalog_role_bindings
  clientRoleBindAll         Boolean      @default(true)

  @@index([name])
  @@index([isActive])
  @@index([quotaUnit])
  @@index([supportsApiKeyCreation])
  @@index([clientRoleBindAll])
  @@map("ai_providers")
}

/// 音色复刻扣费流水（关联 UserApiKey.usedCredits）
model VoiceCloneCreditLog {
  id                 String        @id @default(cuid())
  /// 发起克隆的登录用户（管理员或终端用户）
  actorUserId        String?
  userApiKeyId       String
  providerId         String
  voiceProfileId     String?
  voiceId            String?
  amountCharged      Decimal       @db.Decimal(20, 2)
  keyCreditsCap      Decimal       @db.Decimal(20, 2)
  usedCreditsBefore  Decimal       @db.Decimal(20, 2)
  usedCreditsAfter   Decimal       @db.Decimal(20, 2)
  /// charged | no_charge_configured | admin_exempt（管理员克隆不扣费，仅审计）
  status             String
  meta               String?       @db.Text
  createdAt          DateTime      @default(now())
  actorUser          User?         @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  userApiKey         UserApiKey    @relation(fields: [userApiKeyId], references: [id], onDelete: Cascade)
  provider           AIProvider    @relation(fields: [providerId], references: [id], onDelete: Cascade)
  voiceProfile         VoiceProfile? @relation(fields: [voiceProfileId], references: [id], onDelete: SetNull)

  @@index([userApiKeyId])
  @@index([providerId])
  @@index([actorUserId])
  @@index([voiceProfileId])
  @@index([createdAt])
  @@map("voice_clone_credit_logs")
}

model AIModel {
  id                 String              @id @default(cuid())
  name               String
  displayName        String
  type               String
  category           String?
  providerId         String
  baseUrl            String
  description        String?
  isActive           Boolean             @default(true)
  requiresKey        Boolean             @default(false)
  /// TTS 模型：是否支持语音指令；为 true 时会把绑定该模型的所有音色 supportsVoiceCommand 同步为 true
  supportsVoiceCommand Boolean           @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  apiConfig          String?             @db.Text
  modelTag           String?
  aiCallLogs         AICallLog[]
  provider           AIProvider          @relation(fields: [providerId], references: [id], onDelete: Cascade)
  authorizations     Authorization[]
  prices             ModelPrice[]
  voiceProfileModels VoiceProfileModel[]
  clientRoleBindAll  Boolean             @default(false)

  @@unique([providerId, name])
  @@index([providerId])
  @@index([type])
  @@index([category])
  @@index([isActive])
  @@index([clientRoleBindAll])
  @@map("ai_models")
}

model ModelPrice {
  id          String    @id @default(cuid())
  modelId     String
  packageId   String?
  inputPrice  Decimal   @default(0.000000) @db.Decimal(10, 6)
  outputPrice Decimal   @default(0.000000) @db.Decimal(10, 6)
  callPrice   Decimal   @default(0.00) @db.Decimal(10, 2)
  effectiveAt DateTime  @default(now())
  expiredAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  pricingType String    @default("token")
  maxToken    Int?
  charPrice   Decimal   @default(0.000000) @db.Decimal(10, 6)
  maxChars    Int?
  model       AIModel   @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@index([packageId])
  @@index([pricingType])
  @@index([effectiveAt])
  @@map("model_prices")
}

model VoiceProfileModel {
  voiceProfileId String
  modelId        String
  createdAt      DateTime     @default(now())
  model          AIModel      @relation(fields: [modelId], references: [id], onDelete: Cascade)
  voiceProfile   VoiceProfile @relation(fields: [voiceProfileId], references: [id], onDelete: Cascade)

  @@id([voiceProfileId, modelId])
  @@index([voiceProfileId])
  @@index([modelId])
  @@map("voice_profile_models")
}

model VoiceProfile {
  id            String              @id @default(uuid())
  voiceId       String              @unique
  scope         String
  userId        String?
  sampleUrl     String?
  name          String?
  description   String?
  meta          String?             @db.Text
  supportsVoiceCommand Boolean      @default(false)
  isActive      Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  isModelLocked Boolean             @default(false)
  avatarUrl     String?
  tags          Json?
  models               VoiceProfileModel[]
  user                 User?                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  voiceCloneCreditLogs VoiceCloneCreditLog[]
  clientRoleBindAll    Boolean              @default(true)

  @@index([voiceId])
  @@index([scope])
  @@index([userId])
  @@index([isActive])
  @@index([clientRoleBindAll])
  @@map("voice_profiles")
}

model Package {
  id              String        @id @default(cuid())
  name            String
  displayName     String
  description     String?
  type            String
  clientRoleId    String?
  duration        Int?
  quota           Decimal?      @map("totalQuota") @db.Decimal(20, 2)
  availableModels String?
  isStackable     Boolean       @default(false)
  priority        Int           @default(0)
  isActive        Boolean       @default(true)
  isRecommend     Boolean       @default(false)
  guideScene      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  maxDevices      Int?
  discount        Decimal?      @db.Decimal(5, 2)
  price           Decimal?      @db.Decimal(20, 2)
  priceUnit       String?
  durationUnit    String?
  clientRole       ClientRole?      @relation(fields: [clientRoleId], references: [id], onDelete: SetNull)
  orders           Order[]
  quotaRecords     QuotaRecord[]
  userPackages     UserPackage[]
  activationCodes  ActivationCode[]

  @@index([name])
  @@index([type])
  @@index([isActive])
  @@index([clientRoleId])
  @@map("packages")
}

/// 客户端注册激活码：未使用到期销毁；创建人归属后台管理员便于绩效
model ActivationCode {
  id           String    @id @default(cuid())
  code         String    @unique @db.VarChar(64)
  packageId    String
  /// 可选绑定邮箱：注册时必须用此邮箱
  email        String?
  /// 可选绑定手机：注册时必须用此手机
  phone        String?
  /// unused | used | expired | revoked
  status       String    @default("unused")
  expiresAt    DateTime
  usedAt       DateTime?
  usedByUserId String?
  /// 创建该激活码的后台管理员
  createdBy    String
  batchId      String?
  remark       String?   @db.VarChar(500)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  package      Package   @relation(fields: [packageId], references: [id], onDelete: Restrict)
  usedByUser   User?     @relation("ActivationCodeUsedBy", fields: [usedByUserId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([expiresAt])
  @@index([createdBy])
  @@index([packageId])
  @@index([batchId])
  @@index([deletedAt])
  @@index([email])
  @@index([phone])
  @@map("activation_codes")
}

model UserPackage {
  id        String    @id @default(cuid())
  userId    String
  packageId String
  startedAt DateTime  @default(now())
  expiresAt DateTime?
  priority  Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  package   Package   @relation(fields: [packageId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, packageId])
  @@index([userId])
  @@index([packageId])
  @@index([expiresAt])
  @@map("user_packages")
}

model UserQuota {
  id        String   @id @default(cuid())
  userId    String
  packageId String?
  available Decimal  @default(0.00) @db.Decimal(20, 2)
  frozen    Decimal  @default(0.00) @db.Decimal(20, 2)
  used      Decimal  @default(0.00) @db.Decimal(20, 2)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, packageId])
  @@index([userId])
  @@index([packageId])
  @@map("user_quotas")
}

model QuotaRecord {
  id        String   @id @default(cuid())
  userId    String
  packageId String?
  type      String
  amount    Decimal  @db.Decimal(20, 2)
  before    Decimal  @db.Decimal(20, 2)
  after     Decimal  @db.Decimal(20, 2)
  reason    String?
  requestId String?
  createdAt DateTime @default(now())
  orderId   String?
  order     Order?   @relation(fields: [orderId], references: [id])
  package   Package? @relation(fields: [packageId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([packageId])
  @@index([orderId])
  @@index([type])
  @@index([requestId])
  @@index([createdAt])
  @@map("quota_records")
}

model Order {
  id           String        @id @default(cuid())
  orderNo      String        @unique
  userId       String
  packageId    String
  type         String
  status       String        @default("pending")
  amount       Decimal       @db.Decimal(20, 2)
  currency     String        @default("CNY")
  discount     Decimal?      @db.Decimal(5, 2)
  finalAmount  Decimal       @db.Decimal(20, 2)
  description  String?
  expiresAt    DateTime?
  paidAt       DateTime?
  cancelledAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  package      Package       @relation(fields: [packageId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments     Payment[]
  quotaRecords QuotaRecord[]

  @@index([userId])
  @@index([orderNo])
  @@index([status])
  @@index([createdAt])
  @@index([packageId], map: "orders_packageId_fkey")
  @@map("orders")
}

model Payment {
  id              String    @id @default(cuid())
  orderId         String
  paymentNo       String    @unique
  thirdPartyNo    String?
  paymentMethod   String
  paymentPlatform String
  amount          Decimal   @db.Decimal(20, 2)
  currency        String    @default("CNY")
  status          String    @default("pending")
  qrCodeUrl       String?
  payUrl          String?
  callbackData    String?   @db.Text
  notifyUrl       String?
  paidAt          DateTime?
  failedAt        DateTime?
  failureReason   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([paymentNo])
  @@index([thirdPartyNo])
  @@index([status])
  @@index([paymentPlatform])
  @@index([createdAt])
  @@map("payments")
}

model PromptCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  prompts     Prompt[]

  @@map("prompt_categories")
}

model Prompt {
  id             String          @id @default(cuid())
  title          String
  content        String          @db.Text
  description    String?
  categoryId     String
  tags           String?
  type           String
  userId         String?
  version        Int             @default(1)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  systemId       String?
  functionKey    String          @unique
  isStylePrompt  Boolean         @default(false)
  stylePromptKey String?
  versions       PromptVersion[]
  category       PromptCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  system              Prompt?                    @relation("SystemPrompts", fields: [systemId], references: [id])
  children            Prompt[]                   @relation("SystemPrompts")
  styleLibraryLinks   StyleLibrarySystemPrompt[]
  clientRoleBindAll   Boolean                    @default(true)

  @@index([categoryId])
  @@index([type])
  @@index([userId])
  @@index([systemId])
  @@index([isActive])
  @@index([title])
  @@index([functionKey])
  @@index([clientRoleBindAll])
  @@map("prompts")
}

model PromptVersion {
  id        String   @id @default(cuid())
  promptId  String
  version   Int
  content   String   @db.Text
  updatedBy String?
  createdAt DateTime @default(now())
  prompt    Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([promptId, version])
  @@index([promptId])
  @@index([createdAt])
  @@map("prompt_versions")
}

model StyleLibrarySystemPrompt {
  styleLibraryItemId String
  systemPromptId     String
  createdAt          DateTime         @default(now())
  styleLibraryItem   StyleLibraryItem @relation(fields: [styleLibraryItemId], references: [id], onDelete: Cascade)
  systemPrompt       Prompt           @relation(fields: [systemPromptId], references: [id], onDelete: Restrict)

  @@id([styleLibraryItemId, systemPromptId])
  @@index([styleLibraryItemId])
  @@index([systemPromptId])
  @@map("style_library_system_prompts")
}

model StyleLibraryItem {
  id             String                     @id @default(cuid())
  name           String
  summary        String?
  coverUrl       String?                    @db.Text
  mediaType      String
  stylePromptKey String?
  content        String                     @db.Text
  tags           Json
  usageCount     Int                        @default(0)
  recommendScore Int                        @default(0)
  sortOrder      Int                        @default(0)
  isActive       Boolean                    @default(false)
  isFeatured     Boolean                    @default(false)
  publishedAt    DateTime?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  systemPrompts      StyleLibrarySystemPrompt[]
  clientRoleBindAll  Boolean                    @default(true)

  @@index([mediaType])
  @@index([isActive])
  @@index([isFeatured])
  @@index([recommendScore])
  @@index([sortOrder])
  @@index([createdAt])
  @@index([clientRoleBindAll])
  @@map("style_library_items")
}

model CameraMovementItem {
  id          String   @id @default(cuid())
  movementKey String   @unique
  name        String
  tagLabel    String?
  prompt      String   @db.Text
  previewUrl  String?  @db.Text
  type        String   @default("custom")
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  clientRoleBindAll Boolean  @default(true)

  @@index([type])
  @@index([isActive])
  @@index([sortOrder])
  @@index([createdAt])
  @@index([clientRoleBindAll])
  @@map("camera_movement_items")
}

model BackendMenu {
  id                     String              @id @default(cuid())
  name                   String
  i18nNames              Json                @default("[]")
  path                   String?
  frontendPermissionCode String?
  backendPermissionCode  String?
  parentId               String              @default("0")
  sortOrder              Int                 @default(0)
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  buttons                BackendMenuButton[]

  @@index([parentId])
  @@index([sortOrder])
  @@map("backend_menus")
}

model BackendMenuButton {
  id                     String      @id @default(cuid())
  menuId                 String
  name                   String
  i18nNames              Json        @default("[]")
  isVisible              Boolean     @default(true)
  isDisabled             Boolean     @default(false)
  frontendPermissionCode String?
  backendPermissionCode  String?
  sortOrder              Int         @default(0)
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt
  menu                   BackendMenu @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@index([menuId])
  @@index([sortOrder])
  @@map("backend_menu_buttons")
}

model BackendRole {
  id          String                  @id @default(cuid())
  roleKey     String                  @unique
  name        String
  description String?                 @db.Text
  isSystem    Boolean                 @default(true)
  sortOrder   Int                     @default(0)
  status      String                  @default("active")
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  permissions BackendRolePermission[]

  @@index([status])
  @@index([sortOrder])
  @@map("backend_roles")
}

model BackendRolePermission {
  id         String      @id @default(cuid())
  roleId     String
  targetType String
  targetId   String
  createdAt  DateTime    @default(now())
  role       BackendRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, targetType, targetId])
  @@index([roleId])
  @@index([targetType, targetId])
  @@map("backend_role_permissions")
}

model ClientMenu {
  id                     String             @id @default(cuid())
  name                   String
  i18nNames              Json               @default("[]")
  path                   String?
  frontendPermissionCode String?
  backendPermissionCode  String?
  parentId               String             @default("0")
  sortOrder              Int                @default(0)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  buttons                ClientMenuButton[]

  @@index([parentId])
  @@index([sortOrder])
  @@map("client_menus")
}

model ClientMenuButton {
  id                     String     @id @default(cuid())
  menuId                 String
  name                   String
  i18nNames              Json       @default("[]")
  isVisible              Boolean    @default(true)
  isDisabled             Boolean    @default(false)
  frontendPermissionCode String?
  backendPermissionCode  String?
  sortOrder              Int        @default(0)
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt
  menu                   ClientMenu @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@index([menuId])
  @@index([sortOrder])
  @@map("client_menu_buttons")
}

model ClientRole {
  id          String                 @id @default(cuid())
  roleKey     String                 @unique
  name        String
  description String?                @db.Text
  priority    Int                    @default(0)
  sortOrder   Int                    @default(0)
  status      String                 @default("active")
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  permissions ClientRolePermission[]
  packages    Package[]
  catalogRoleBindings CatalogRoleBinding[]

  @@index([status])
  @@index([sortOrder])
  @@index([priority])
  @@map("client_roles")
}

model CatalogRoleBinding {
  id         String     @id @default(cuid())
  targetType String
  targetId   String
  roleId     String
  createdAt  DateTime   @default(now())
  role       ClientRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([targetType, targetId, roleId])
  @@index([targetType, targetId])
  @@index([roleId])
  @@map("catalog_role_bindings")
}

model ClientRolePermission {
  id         String     @id @default(cuid())
  roleId     String
  targetType String
  targetId   String
  createdAt  DateTime   @default(now())
  role       ClientRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, targetType, targetId])
  @@index([roleId])
  @@index([targetType, targetId])
  @@map("client_role_permissions")
}

model UserApiKey {
  id             String          @id @default(cuid())
  userId         String?
  providerId     String
  apiKey         String          @db.Text
  apiKeyId       String?
  name           String
  type           String
  credits        Decimal         @default(0.00) @db.Decimal(20, 2)
  expireTime     BigInt          @default(0)
  status         String          @default("active")
  packageId      String?
  createdBy      String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  voiceLimit     Int             @default(0)
  usedCredits    Decimal         @default(0.00) @db.Decimal(20, 2)
  authorizations       Authorization[]
  provider             AIProvider            @relation(fields: [providerId], references: [id], onDelete: Cascade)
  user                 User?                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  voiceCloneCreditLogs VoiceCloneCreditLog[]

  @@index([userId])
  @@index([providerId])
  @@index([status])
  @@index([type])
  @@index([expireTime])
  @@index([packageId])
  @@map("user_api_keys")
}

model Authorization {
  id                String      @id @default(cuid())
  userId            String
  modelId           String
  deviceFingerprint String
  ipAddress         String?
  frozenQuota       Decimal     @db.Decimal(20, 2)
  status            String      @default("active")
  expiresAt         DateTime
  requestId         String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  callToken         String?     @unique
  userApiKeyId      String?
  model             AIModel     @relation(fields: [modelId], references: [id], onDelete: Cascade)
  userApiKey        UserApiKey? @relation(fields: [userApiKeyId], references: [id])
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([modelId])
  @@index([callToken])
  @@index([status])
  @@index([expiresAt])
  @@index([requestId])
  @@index([userApiKeyId])
  @@map("authorizations")
}

model OperationLog {
  id           String   @id @default(cuid())
  adminId      String
  action       String
  targetType   String
  targetId     String?
  details      String?  @db.Text
  ipAddress    String?
  result       String   @default("success")
  errorMessage String?  @db.Text
  createdAt    DateTime @default(now())
  admin        Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([action])
  @@index([targetType])
  @@index([targetId])
  @@index([createdAt])
  @@map("operation_logs")
}

model AICallLog {
  id                String    @id @default(cuid())
  requestId         String    @unique
  userId            String
  modelId           String
  inputTokens       Int       @default(0)
  outputTokens      Int       @default(0)
  totalTokens       Int       @default(0)
  cost              Decimal   @db.Decimal(10, 4)
  status            String
  errorMessage      String?   @db.Text
  requestTime       DateTime  @default(now())
  responseTime      DateTime?
  duration          Int?
  deviceFingerprint String?
  ipAddress         String?
  model             AIModel   @relation(fields: [modelId], references: [id], onDelete: Cascade)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([modelId])
  @@index([status])
  @@index([requestTime])
  @@index([requestId])
  @@map("ai_call_logs")
}

model RiskRule {
  id           String   @id @default(cuid())
  name         String   @unique
  description  String?
  conditions   String   @db.Text
  action       String
  actionParams String?  @db.Text
  priority     Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive])
  @@index([priority])
  @@map("risk_rules")
}

model RiskTrigger {
  id           String   @id @default(cuid())
  ruleId       String
  userId       String?
  modelId      String?
  conditions   String   @db.Text
  action       String
  actionResult String?  @db.Text
  status       String   @default("pending")
  createdAt    DateTime @default(now())

  @@index([ruleId])
  @@index([userId])
  @@index([modelId])
  @@index([status])
  @@index([createdAt])
  @@map("risk_triggers")
}

model OtaRelease {
  id              String    @id @default(cuid())
  layer           String
  platform        String
  bundleType      String?
  updateMethod    String?
  channel         String    @default("stable")
  version         String
  buildNumber     Int
  minBaseBuild    Int?
  minBackendBuild Int?
  downloadUrl     String    @db.Text
  feedUrl         String?   @db.Text
  fileSize        BigInt
  sha256          String
  signature       String?   @db.Text
  releaseNotes    String?   @db.Text
  forceUpdate     Boolean   @default(false)
  rolloutPercent  Int       @default(100)
  /// { deviceIds?: string[] } — 非空时仅名单内设备可拉取；再叠加 rolloutPercent
  rolloutRule     Json?
  isPublished     Boolean   @default(false)
  /// 对客户端生效时间；null 视为立即。定时发布时 isPublished=true 且 publishAt 为未来时间
  publishAt       DateTime?
  publishedAt     DateTime?
  createdBy       String?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([layer, platform, channel, buildNumber, bundleType, updateMethod], map: "ota_releases_layer_platform_channel_build_bundle_key")
  @@index([layer, platform, channel, isPublished, buildNumber])
  @@index([isPublished])
  @@index([publishAt])
  @@index([deletedAt])
  @@map("ota_releases")
}

model OtaReport {
  id        String   @id @default(cuid())
  deviceId  String
  event     String
  layer     String?
  fromBuild Int?
  toBuild   Int?
  platform  String?
  channel   String?
  error     String?  @db.Text
  createdAt DateTime @default(now())

  @@index([deviceId])
  @@index([event])
  @@index([layer])
  @@index([createdAt])
  @@map("ota_reports")
}
